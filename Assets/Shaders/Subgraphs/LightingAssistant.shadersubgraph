    "m_SourceType": 1,
    "m_FunctionName": "VertexLit",
    "m_FunctionSource": "",
    "m_FunctionBody": "#if SHADERGRAPH_PREVIEW\r\n    float3 lightDir = normalize(float3(0.5, 1.0, 0.5)); // top-right-ish direction\r\n    float NdotL = saturate(dot(NormalWS, lightDir));\r\n    VertexLight = NdotL;\r\n#else\r\n    float3 vertexLight = VertexLighting(PositionWS, NormalWS);\r\n\r\n    Light mainLight = GetMainLight();\r\n    float NdotL = saturate(dot(NormalWS, mainLight.direction));\r\n    vertexLight += mainLight.color * NdotL;\r\n\r\n    VertexLight = vertexLight;\r\n#endif"
}

